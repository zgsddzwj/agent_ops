FROM python:3.11-slim
WORKDIR /app
RUN pip install uv
COPY pyproject.toml backend/pyproject.toml packages/agent-ops-sdk/pyproject.toml ./
COPY backend/ ./backend/
COPY packages/agent-ops-sdk/ ./packages/agent-ops-sdk/
RUN pip install -e ./packages/agent-ops-sdk -e ./backend
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]
