# ─── Database ───
DATABASE_URL=postgresql+asyncpg://agentops:agentops@localhost:5432/agentops
DATABASE_URL_SYNC=postgresql://agentops:agentops@localhost:5432/agentops

# ─── Redis ───
REDIS_URL=redis://localhost:6379/0

# ─── Security (CHANGE IN PRODUCTION!) ───
SECRET_KEY=change-me-in-production

# ─── API Settings ───
CORS_ORIGINS=http://localhost:3000
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false
LOG_REQUESTS=false
API_TIMEOUT=30

# ─── Rate Limiting ───
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# ─── LLM API Keys (for eval/benchmark) ───
OPENAI_API_KEY=
DASHSCOPE_API_KEY=
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=

# ─── AgentOps SDK ───
AGENT_OPS_API_URL=http://localhost:8000
AGENT_OPS_API_KEY=

# ─── Frontend ───
NEXT_PUBLIC_API_URL=http://localhost:8000
